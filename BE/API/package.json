{
  "name": "@omne-showcase/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test",
    "swagger:generate": "tsx src/scripts/generate-openapi.ts",
    "db:up": "docker compose -f ../../docker-compose.yml up -d postgres",
    "db:migrate": "docker compose -f ../../docker-compose.yml run --rm flyway",
    "db:down": "docker compose -f ../../docker-compose.yml down -v"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
